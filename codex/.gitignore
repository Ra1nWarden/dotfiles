# Track only portable Codex configuration.
# The live ~/.codex/config.toml is machine-owned and generated by codex-sync;
# it is never tracked here.
*
!.gitignore
!config.portable.toml
!portable-keys.txt
!AGENTS.md
!bin/
!bin/*
!vendor/
!vendor/**
!hooks/
!hooks/*
!rules/
!rules/*.rules
!agents/
!agents/*.toml
!skills/
!skills/*/
!skills/*/SKILL.md
