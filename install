#!/usr/bin/env bash

set -e

CONFIG="install.conf.yaml"
DOTBOT_DIR="dotbot"

DOTBOT_BIN="bin/dotbot"
BASEDIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

cd "${BASEDIR}"
git -C "${DOTBOT_DIR}" submodule sync --quiet --recursive
git submodule update --init --recursive "${DOTBOT_DIR}"

"${BASEDIR}/${DOTBOT_DIR}/${DOTBOT_BIN}" -d "${BASEDIR}" -c "${CONFIG}" "${@}"

# Blueprints setup
# Read BLUEPRINTS_DIR without sourcing zsh-only startup code under bash.
if [ -z "${BLUEPRINTS_DIR:-}" ] && [ -f ~/.zshrc.local ]; then
  BLUEPRINTS_DIR="$(
    sed -n 's/^[[:space:]]*export[[:space:]]\+BLUEPRINTS_DIR=//p' ~/.zshrc.local | tail -n 1
  )"
  BLUEPRINTS_DIR="${BLUEPRINTS_DIR/#\~/$HOME}"
  BLUEPRINTS_DIR="${BLUEPRINTS_DIR%\"}"
  BLUEPRINTS_DIR="${BLUEPRINTS_DIR#\"}"
  BLUEPRINTS_DIR="${BLUEPRINTS_DIR%\'}"
  BLUEPRINTS_DIR="${BLUEPRINTS_DIR#\'}"
  [ -n "$BLUEPRINTS_DIR" ] && export BLUEPRINTS_DIR
fi

if [ -z "$BLUEPRINTS_DIR" ] && [ -t 0 ]; then
  echo ""
  echo "=== Claude Code Blueprints Setup ==="
  echo "Blueprints store design specs, plans, and reviews in a git-tracked directory."
  echo ""
  printf "Enter blueprints directory path (e.g., ~/personal/blueprints), or press Enter to skip: "
  read -r BLUEPRINTS_PATH

  if [ -n "$BLUEPRINTS_PATH" ]; then
    # Expand ~ to $HOME
    BLUEPRINTS_PATH="${BLUEPRINTS_PATH/#\~/$HOME}"

    # Append to .zshrc.local
    echo "" >> ~/.zshrc.local
    echo "export BLUEPRINTS_DIR=\"$BLUEPRINTS_PATH\"" >> ~/.zshrc.local

    # Create directory and init git repo
    mkdir -p "$BLUEPRINTS_PATH"
    if [ ! -d "$BLUEPRINTS_PATH/.git" ]; then
      git -C "$BLUEPRINTS_PATH" init
      echo "Initialized blueprints repo at $BLUEPRINTS_PATH"
    fi

    export BLUEPRINTS_DIR="$BLUEPRINTS_PATH"
    echo "BLUEPRINTS_DIR set to $BLUEPRINTS_PATH"
    echo "Remember to add a git remote: cd $BLUEPRINTS_PATH && git remote add origin <url>"
  else
    echo "Skipped. You can set it later in ~/.zshrc.local:"
    echo "  export BLUEPRINTS_DIR=~/path/to/blueprints"
  fi
fi
